rules_version = '2';

// قواعد أمان Firebase Storage لتطبيق "سند"
// انسخ هذا الملف بالكامل إلى:
// Firebase Console > Storage > Rules

service firebase.storage {
  match /b/{bucket}/o {

    // معرض أعمال الحرفي - كل حرفي يكتب في مجلده فقط
    match /portfolio/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.size < 5 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }

    // الصور الشخصية
    match /avatars/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.size < 5 * 1024 * 1024;
    }

    // إيصالات تحويل المحفظة
    match /walletReceipts/{userId}/{fileName} {
      allow read: if request.auth != null
                    && (request.auth.uid == userId
                        || request.auth.uid == "JBtQBKkpMvOT58abx2wZqOtxNwU2");
      allow write: if request.auth != null
                    && request.auth.uid == userId;
    }
  }
}
